# Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Naver 검색 API (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 나라장터 공공데이터 API (https://www.data.go.kr → "나라장터 입찰공고정보 서비스" 활용신청)
PROCUREMENT_API_KEY=

# 사람인 Open API (https://oapi.saramin.co.kr → 서비스 키 신청)
SARAMIN_API_KEY=

# Supabase PostgreSQL (prod 프로파일 사용 시 필수)
# Supabase 대시보드 > Settings > Database > Connection string (JDBC)
DB_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=
